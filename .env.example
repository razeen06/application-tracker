FLASK_SECRET_KEY=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" only for local development. Must be unset/false in
# production -- app.py refuses to start without FLASK_SECRET_KEY when this
# is false, rather than silently falling back to an insecure default.
FLASK_DEBUG=true

# Chrome extension's origin, e.g. chrome-extension://<extension-id>.
# When set, /api/* responds with CORS headers allowing that origin.
# Leave unset locally -- the dashboard itself doesn't need CORS.
EXTENSION_ORIGIN=

# Not needed locally (defaults to a local SQLite file). Render injects this
# automatically when the web service is linked to a Postgres database via
# render.yaml's fromDatabase reference.
DATABASE_URL=
