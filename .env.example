FLASK_SECRET_KEY=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" only for local development. Must be unset/false in
# production -- app.py refuses to start without FLASK_SECRET_KEY when this
# is false, rather than silently falling back to an insecure default.
FLASK_DEBUG=true

# Chrome extension's origin, e.g. chrome-extension://<extension-id>.
# When set, /api/* responds with CORS headers allowing that origin.
# Leave unset locally -- the dashboard itself doesn't need CORS.
EXTENSION_ORIGIN=

# Not needed locally (defaults to a local SQLite file). Render injects this
# automatically when the web service is linked to a Postgres database via
# render.yaml's fromDatabase reference.
DATABASE_URL=

# Required for POST /api/summarize (AI job-posting summaries). Get one from
# https://aistudio.google.com/apikey. Without this set, the route returns
# {"error": "Summary unavailable"} instead of calling Gemini.
GEMINI_API_KEY=

# Required for /connect-gmail (Gmail read-access OAuth). Used to encrypt the
# stored Gmail refresh token at rest with Fernet symmetric encryption --
# without this set, /gmail-callback raises rather than storing a token in
# plaintext. Generate one locally with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Set the same value on Render's dashboard (not committed, sync: false) --
# rotating it invalidates any already-stored Gmail tokens (they'd need to be
# reconnected).
GMAIL_TOKEN_ENCRYPTION_KEY=

# The Chrome extension's ID, used by the dashboard's "Connect Extension"
# button to message it directly via chrome.runtime.sendMessage(EXTENSION_ID, ...).
# Defaults to the current dev/unpacked extension's ID if unset. IMPORTANT:
# once this extension is published to the Chrome Web Store, Chrome assigns a
# new PERMANENT id that is different from the unpacked dev id below -- update
# this value (here and on Render) to that new id, or "Connect Extension" will
# silently target the wrong (old, no-longer-loaded) extension.
EXTENSION_ID=omfepdnjidhlachagnbielicaghjpdkm
